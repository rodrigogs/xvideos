{
  "name": "@rodrigogs/xvideos",
  "description": "xvideos.com api implementation.",
  "version": "2.0.0",
  "type": "module",
  "main": "dist/cjs/index.cjs",
  "types": "dist/types/index.d.ts",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/rodrigogs/xvideos.git"
  },
  "keywords": [
    "crawler",
    "porn",
    "spider",
    "scraper",
    "api",
    "xvideos",
    "library"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json && tsc -p tsconfig.cjs.json",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "coverage": "vitest run --project unit --coverage",
    "test:junit": "vitest run --reporter=default --reporter=junit --outputFile=test-report.junit.xml"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "got-scraping": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@biomejs/biome": "^2.4.13",
    "@vitest/coverage-v8": "^4.1.5",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
