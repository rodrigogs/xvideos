{
	"name": "@rodrigogs/xvideos",
	"description": "xvideos.com api implementation.",
	"version": "1.3.0",
	"type": "module",
	"main": "dist/cjs/index.cjs",
	"types": "dist/types/index.d.ts",
	"license": "BSD-3-Clause",
	"repository": {
		"type": "git",
		"url": "https://github.com/rodrigogs/xvideos.git"
	},
	"keywords": [
		"crawler",
		"porn",
		"spider",
		"scrapper",
		"api",
		"xvideos",
		"api",
		"library"
	],
	"scripts": {
		"build": "tsx ./scripts/build.ts",
		"lint": "tsx ./scripts/biome.ts check",
		"format": "tsx ./scripts/biome.ts format --write",
		"prepublishOnly": "npm run build",
		"test": "vitest run",
		"test:unit": "vitest run --project unit",
		"test:integration": "vitest run --project integration",
		"coverage": "vitest run --project unit --coverage"
	},
	"dependencies": {
		"cheerio": "^1.2.0",
		"got-scraping": "^4.2.1"
	},
	"devDependencies": {
		"@types/node": "^24.10.1",
		"@biomejs/js-api": "^4.0.0",
		"@biomejs/wasm-nodejs": "^2.4.13",
		"@vitest/coverage-v8": "^4.1.5",
		"tsx": "^4.20.6",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=20.18.1"
	},
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/esm/index.js",
			"require": "./dist/cjs/index.cjs",
			"default": "./dist/esm/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	]
}
